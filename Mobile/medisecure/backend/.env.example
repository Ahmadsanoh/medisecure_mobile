# MediSecure Backend — Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL connection (async)
DATABASE_URL=postgresql+asyncpg://medisecure:medisecure_pass@localhost:5432/medisecure_db

# JWT secret key — MUST be changed in production (use: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# Optional: SMTP for real email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password

# Optional: Firebase FCM for push notifications
FCM_SERVER_KEY=your_firebase_server_key
